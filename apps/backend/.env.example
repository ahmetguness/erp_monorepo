# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/axonerp?schema=public"
# Production pool sizing:
# - Keep total backend instances * connection_limit below Postgres max connections.
# - Prefer PgBouncer or a managed pooled URL for horizontal scaling.
# - Example direct app pool: ?schema=public&connection_limit=5&pool_timeout=10
# - Example PgBouncer URL: ?schema=public&pgbouncer=true&connection_limit=5&pool_timeout=10

# Server
PORT=3001
NODE_ENV=development
# API process by default. Use APP_ROLE=worker for dedicated background
# workers, or APP_ROLE=all when this process should run API + workers.
# APP_ROLE=api

# Auth
# Required secrets
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=7d
ADMIN_JWT_SECRET=your-admin-jwt-secret-here
# Required: application-level encryption for marketplace credentials and other encrypted fields.
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# Resend Mail
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="Axon ERP <noreply@axonerp.com>"

# Demo
APP_URL="http://localhost:3000"
SALES_NOTIFICATION_EMAIL="sales@axonerp.com"

# CORS
ALLOWED_ORIGINS="http://localhost:3000,https://app.axonerp.com"

# Security headers
# Options: report-only, enforce, both. Default in code is both.
CONTENT_SECURITY_POLICY_MODE=both

# OpenAI
OPENAI_API_KEY="sk-your-openai-api-key-here"
# Public chat abuse/cost controls
PUBLIC_CHAT_SESSION_DAILY_LIMIT=30
PUBLIC_CHAT_DAILY_REQUEST_BUDGET=1000

# Attachments
# Dev default is local. Production default is R2 object storage.
STORAGE_DRIVER=local
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=axon-erp-uploads
# Optional, defaults to https://{R2_ACCOUNT_ID}.r2.cloudflarestorage.com
# R2_ENDPOINT="https://your-account-id.r2.cloudflarestorage.com"
# Local uploads are for development/single-node deployments only.
# In production, keep this false unless a temporary local fallback is explicitly accepted.
ALLOW_LOCAL_UPLOADS_IN_PRODUCTION=false

# Marketplace Mock — gerçek hesap olmadan test için (opsiyonel)
# Canonical setting: use MARKETPLACE_MOCK. TRENDYOL_MOCK=true is a legacy alias
# kept for older local scripts only; do not use either mock switch in production.
# Tek kanal:  MARKETPLACE_MOCK=trendyol
# Çok kanal:  MARKETPLACE_MOCK=trendyol,hepsiburada
# Hepsi:      MARKETPLACE_MOCK=all
# Kapalı:     satırı sil veya boş bırak
# MARKETPLACE_MOCK=trendyol
# TRENDYOL_MOCK=true

# Redis — opsiyonel, çok process/pod çalıştırılacaksa rate limiter için
# REDIS_URL="redis://localhost:6379"
GLOBAL_RATE_LIMIT_PER_MINUTE=300
GLOBAL_WRITE_RATE_LIMIT_PER_MINUTE=120

# Worker — opsiyonel, birden fazla worker pod çalıştırılacaksa
# Worker is disabled by default for API/dev processes to avoid background DB polling.
# Enable only in the dedicated worker process/pod, or set APP_ROLE=worker/all.
# MARKETPLACE_WORKER_ENABLED=true
# DOMAIN_EVENT_OUTBOX_WORKER_ENABLED=true
# DOMAIN_EVENT_OUTBOX_WORKER_INTERVAL_MS=10000
# WORKER_CONCURRENCY=2

# Production deploy sizing:
# - Marketplace jobs and domain event outbox replays use DB claims/idempotency.
# - Size worker instances separately from API traffic capacity.
# - Count API and worker instances in the Postgres connection budget above.
