# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/axonerp?schema=public"

# Server
PORT=3001
NODE_ENV=development

# Auth
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=7d
ADMIN_JWT_SECRET=your-admin-jwt-secret-here

# Resend Mail
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="Axon ERP <noreply@axonerp.com>"

# Demo
APP_URL="http://localhost:3000"
SALES_NOTIFICATION_EMAIL="sales@axonerp.com"

# CORS
ALLOWED_ORIGINS="http://localhost:3000,https://app.axonerp.com"

# OpenAI
OPENAI_API_KEY="sk-your-openai-api-key-here"
