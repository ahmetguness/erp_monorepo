DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/axonerp?schema=public"
PORT=3001
NODE_ENV=development
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=7d
ADMIN_JWT_SECRET=your-admin-jwt-secret-here

# Resend Mail
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="Axon ERP <noreply@axonerp.com>"

# Demo
APP_URL="http://localhost:3000"
SALES_NOTIFICATION_EMAIL="sales@axonerp.com"

# CORS
ALLOWED_ORIGINS="http://localhost:3000,https://app.axonerp.com"

# n8n Chatbot (internal — ASLA client'a expose etme)
N8N_INTERNAL_WEBHOOK_URL="http://n8n:5678/webhook/chatbot"
N8N_SHARED_SECRET="your-n8n-shared-secret-here"
SERVICE_JWT_SECRET="your-service-jwt-secret-here"
