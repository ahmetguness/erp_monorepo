model CustomerAsset {
  id           String    @id @default(cuid())
  tenantId     String
  contactId    String
  name         String
  brand        String?
  model        String?
  serialNo     String?
  purchaseDate DateTime? @db.Date
  warrantyEnd  DateTime? @db.Date
  notes        String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  createdById  String?

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact         Contact          @relation(fields: [contactId], references: [id])
  serviceRequests ServiceRequest[]

  @@index([tenantId, contactId])
  @@index([tenantId, serialNo])
  @@map("customer_assets")
}

// Fix #6: Replaced priority Int with Priority enum
model ServiceRequest {
  id              String        @id @default(cuid())
  tenantId        String
  contactId       String?
  customerAssetId String?
  number          String
  status          ServiceStatus @default(OPEN)
  subject         String
  description     String?
  warrantyEnd     DateTime?
  assignedToId    String?
  priority        Priority      @default(MEDIUM)
  closedAt        DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?
  createdById     String?
  updatedById     String?

  tenant        Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact       Contact?                @relation(fields: [contactId], references: [id])
  customerAsset CustomerAsset?          @relation(fields: [customerAssetId], references: [id])
  items         ServiceRequestItem[]
  activities    ServiceActivity[]
