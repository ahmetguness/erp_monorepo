}

model ServiceRequestItem {
  id               String  @id @default(cuid())
  tenantId         String
  serviceRequestId String
  productId        String?
  description      String
  quantity         Decimal @db.Decimal(18, 3) @default(1)
  unitPrice        Decimal @db.Decimal(18, 2) @default(0)
  lineTotal        Decimal @db.Decimal(18, 2) @default(0)

  serviceRequest ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  product        Product?       @relation(fields: [productId], references: [id])
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, serviceRequestId])
  @@map("service_request_items")
}

model ServiceActivity {
  id               String              @id @default(cuid())
  tenantId         String
  serviceRequestId String
  actorId          String?
  activityType     ServiceActivityType
  notes            String?
  createdAt        DateTime            @default(now())

  serviceRequest ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, serviceRequestId])
  @@map("service_activities")
}

model ServiceRequestHistory {
  id               String         @id @default(cuid())
  tenantId         String
  serviceRequestId String
  fromStatus       ServiceStatus?
  toStatus         ServiceStatus
  notes            String?
  createdAt        DateTime       @default(now())
  createdById      String?

  serviceRequest ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, serviceRequestId])
  @@map("service_request_history")
}

// ═════════════════════════════════════════════
// E-TİCARET
// ═════════════════════════════════════════════

model MarketplaceIntegration {
  id         String             @id @default(cuid())
  tenantId   String
  channel    MarketplaceChannel
  name       String
  apiKey     String?
  apiSecret  String?
  storeId    String?
  isActive   Boolean            @default(true)
  lastSyncAt DateTime?
  syncErrors Int                @default(0)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  tenant   Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  listings MarketplaceListing[]
  orders   MarketplaceOrder[]
  syncJobs     MarketplaceSyncJob[]
  webhookEvents MarketplaceWebhookEvent[]

  @@unique([tenantId, channel])
  @@map("marketplace_integrations")
}

// Minor fix: stock changed to Decimal for consistency with StockLevel.quantity
model MarketplaceListing {
  id            String    @id @default(cuid())
  tenantId      String
  integrationId String
  productId     String
  externalId    String
  externalSku   String?
  price         Decimal   @db.Decimal(18, 2)
  stock         Decimal   @db.Decimal(18, 3) @default(0)
  isActive      Boolean   @default(true)
  lastSyncAt    DateTime?
  syncError     String?

  integration MarketplaceIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  product     Product                @relation(fields: [productId], references: [id])
  tenant      Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  snapshot    MarketplaceListingSnapshot?

  @@unique([integrationId, externalId])
  @@index([tenantId, productId])
  @@map("marketplace_listings")
}
model MarketplaceOrder {
  id              String                 @id @default(cuid())
  tenantId        String
  integrationId   String
  externalId      String
  channel         MarketplaceChannel
  status          MarketplaceOrderStatus @default(PENDING)
  customerName    String?
  customerEmail   String?
  customerPhone   String?
  shippingAddress String?
  totalAmount     Decimal                @db.Decimal(18, 2)
  orderDate       DateTime
  syncedAt        DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  integration MarketplaceIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  items       MarketplaceOrderItem[]
  tenant      Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([integrationId, externalId])
  @@index([tenantId, channel])
  @@index([tenantId, status])
  @@map("marketplace_orders")
}

model MarketplaceOrderItem {
  id                 String  @id @default(cuid())
  tenantId           String
  marketplaceOrderId String
  externalProductId  String
  productId          String?
  name               String
  quantity           Int
  unitPrice          Decimal @db.Decimal(18, 2)
  lineTotal          Decimal @db.Decimal(18, 2)

  marketplaceOrder MarketplaceOrder @relation(fields: [marketplaceOrderId], references: [id], onDelete: Cascade)
  product          Product?         @relation(fields: [productId], references: [id])
  tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, marketplaceOrderId])
  @@map("marketplace_order_items")
}

// ═════════════════════════════════════════════
// MARKETPLACE — SYNC STATE & WEBHOOK
// ═════════════════════════════════════════════

/// Trendyol (ve diğer kanal) sync işlemlerinin durumunu izler.
/// Her sync job bir kayıt oluşturur; queue worker bu tabloyu okur.
model MarketplaceSyncJob {
  id            String        @id @default(cuid())
  tenantId      String
  integrationId String
  jobType       SyncJobType
  status        SyncJobStatus @default(PENDING)
  startedAt     DateTime?
  finishedAt    DateTime?
  /// Kaç kayıt işlendi
  processedCount Int          @default(0)
  /// Kaç kayıt hata verdi
  errorCount    Int           @default(0)
  /// Hata mesajı (varsa)
  errorMessage  String?
  /// Job parametreleri (JSON): hoursBack, status filtresi vb.
  params        Json?
  /// Sonuç özeti (JSON): created, updated, skipped, batchIds vb.
  result        Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  integration MarketplaceIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  tenant      Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, integrationId, status])
  @@index([tenantId, jobType, status])
  @@index([createdAt])
  @@map("marketplace_sync_jobs")
}

/// Trendyol webhook event'lerini idempotent şekilde işlemek için.
/// Her event bir kez işlenir; tekrar gelirse atlanır.
model MarketplaceWebhookEvent {
  id            String   @id @default(cuid())
  tenantId      String
  integrationId String
  /// Trendyol'un gönderdiği event ID (idempotency key)
  eventId       String
  eventType     String   // 'ORDER_STATUS_CHANGED' | 'STOCK_UPDATED' vb.
  payload       Json
  processedAt   DateTime?
  errorMessage  String?
  createdAt     DateTime @default(now())

  integration MarketplaceIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  tenant      Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([integrationId, eventId])
  @@index([tenantId, processedAt])
  @@map("marketplace_webhook_events")
}

/// Stok/fiyat güncelleme için değişiklik takibi.
/// Son gönderilen değerleri saklar; değişmemişse tekrar göndermez.
/// 15 dk duplicate koruması için lastSentAt kullanılır.
model MarketplaceListingSnapshot {
  id            String   @id @default(cuid())
  tenantId      String
  listingId     String   @unique
  lastSentQty   Decimal  @db.Decimal(18, 3)
  lastSentSalePrice  Decimal @db.Decimal(18, 2)
  lastSentListPrice  Decimal @db.Decimal(18, 2)
  lastSentAt    DateTime
  batchRequestId String?

  listing MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  tenant  Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("marketplace_listing_snapshots")
}

// ═════════════════════════════════════════════
// RAPORLAMA
// ═════════════════════════════════════════════

model SavedReport {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  module    String
  filters   Json     @default("{}")
  columns   String[] @default([])
  isShared  Boolean  @default(false)
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, module])
  @@map("saved_reports")
}

enum SavedViewScope {
  PERSONAL
  TENANT
  ROLE
}

enum DomainEventOutboxStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
  DEAD_LETTER
}

model SavedView {
  id          String         @id @default(cuid())
  tenantId    String
  userId      String?
  roleId      String?
  name        String
  module      String
  listKey     String
  scope       SavedViewScope @default(PERSONAL)
  state       Json           @default("{}")
  isDefault   Boolean        @default(false)
  createdById String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, listKey])
  @@index([tenantId, userId])
  @@index([tenantId, roleId])
  @@map("saved_views")
}

model DomainEventOutbox {
  id              String                  @id @default(cuid())
  tenantId        String
  name            String
  schemaVersion   Int                     @default(1)
  source          String
  idempotencyKey  String
  entityType      EntityType
  entityId        String
  payload         Json
  context         Json
  status          DomainEventOutboxStatus @default(PENDING)
  attempts        Int                     @default(0)
  lastError       String?
  failedListeners Json?
  nextRetryAt     DateTime?
  processedAt     DateTime?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, status, createdAt])
  @@index([tenantId, name, createdAt])
  @@index([tenantId, entityType, entityId])
  @@map("domain_event_outbox")
}

// ═════════════════════════════════════════════
// DEMO REQUEST
// ═════════════════════════════════════════════

enum DemoRequestStatus {
  PENDING
  APPROVED
  PROVISIONING
  PROVISIONED
  REJECTED
  EXPIRED
  CANCELLED
}

model DemoRequest {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fullName    String
  companyName String
  email       String
  phone       String?
  plan        Plan       @default(STARTER)
  status      DemoRequestStatus @default(PENDING)

  /// Provisioning sonrası oluşturulan tenant
  tenantId    String?
  /// Şifre belirleme token'ı
  setPasswordToken   String?
  setPasswordExpiry  DateTime?

  notes       String?
  rejectedReason String?
  processedAt DateTime?
  processedBy String?

  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@index([email])
  @@index([status])
  @@index([tenantId])
  @@index([createdAt])
