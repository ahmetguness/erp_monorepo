  isPosted       Boolean          [default: false]
  postedAt       DateTime         [null]
  postedById     String           [null]
  createdAt      DateTime
  updatedAt      DateTime
  createdById    String           [null]

  indexes {
    (tenantId, number) [unique]
    (tenantId, date)
    (tenantId, isPosted)
    (refType, refId)
  }
}

Ref: journal_entries.tenantId > tenants.id [delete: cascade]
Ref: journal_entries.fiscalPeriodId > fiscal_periods.id

Table journal_entry_lines {
  id             String  [pk]
