Table work_orders {
  id          String          [pk]
  tenantId    String
  bomId       String          [null]
  productId   String
  number      String
  status      WorkOrderStatus [default: "PLANNED"]
  plannedQty  Decimal
  producedQty Decimal         [default: 0]
  startDate   DateTime        [null]
  endDate     DateTime        [null]
  inputWarehouseId  String    [null]
  outputWarehouseId String    [null]
  notes       String          [null]
  createdAt   DateTime
  updatedAt   DateTime
