  journalEntryId String
  accountId      String
  debit          Decimal [default: 0]
  credit         Decimal [default: 0]
  description    String  [null]
  sortOrder      Int     [default: 0]

  indexes {
    (tenantId, journalEntryId)
    (tenantId, accountId)
  }
}

Ref: journal_entry_lines.journalEntryId > journal_entries.id [delete: cascade]
Ref: journal_entry_lines.accountId > ledger_accounts.id

Table reconciliations {
  id             String   [pk]
