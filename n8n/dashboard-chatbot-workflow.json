        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"gpt-4o-mini\",\n  \"temperature\": 0.3,\n  \"max_tokens\": 1000,\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"Sen {{ $('Config').item.json.tenantName }} sirketinin Axon ERP asistanisin.\\n\\nKURALLAR:\\n1. SADECE sana verilen ERP verisini kullan. Veri disinda bilgi uydurma.\\n2. Baska sirket veya tenant hakkinda bilgi verme.\\n3. TC kimlik, IBAN, kredi karti, sifre gibi hassas bilgileri ASLA paylasma.\\n4. Turkce yanit ver. Para birimlerini TL ile goster.\\n5. Kisa ve oz yanit ver.\\n6. Veri yoksa bunu acikca belirt.\\n7. Eger ERP verisi bos, hata iceriyor veya alinamadiysa bunu acikca belirt ve genel yonlendirme yap.\\n\\nKullanici: {{ $('Config').item.json.userName }}\\nPlan: {{ $('Config').item.json.plan }}\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Soru: {{ $('Config').item.json.message }}\\n\\nERP Verisi:\\n{{ JSON.stringify($json.data || $json, null, 2) }}\"\n    }\n  ]\n}",
        "options": {
          "timeout": 25000
        }
      },
      "id": "a1000001-0001-4000-8000-000000000012",
      "name": "AI Yanit Veri",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1740, 280],
      "credentials": {
        "openAiApi": {
