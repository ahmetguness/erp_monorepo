        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"gpt-4o-mini\",\n  \"temperature\": 0.5,\n  \"max_tokens\": 500,\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"Sen {{ $('Config').item.json.tenantName }} sirketinin Axon ERP asistanisin. Bu genel bir soru, ERP verisi cekilmedi. Sadece ERP kullanimi hakkinda yardimci ol. Baska sirket bilgisi verme. Turkce yanit ver. Kisa tut.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": {{ JSON.stringify($('Config').item.json.message) }}\n    }\n  ]\n}",
        "options": {
          "timeout": 25000
        }
      },
