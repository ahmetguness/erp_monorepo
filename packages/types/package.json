{
  "name": "@repo/types",
  "version": "0.0.1",
  "type": "commonjs",
  "main": "./index.ts",
  "types": "./index.ts",
  "exports": {
    ".": {
      "types": "./index.ts",
      "default": "./index.ts"
    },
    "./contracts": {
      "types": "./contracts/index.ts",
      "require": "./contracts/index.js",
      "import": "./contracts/index.ts",
      "default": "./contracts/index.ts"
    },
    "./contracts/api-key": {
      "types": "./contracts/api-key.ts",
      "require": "./contracts/api-key.js",
      "import": "./contracts/api-key.ts",
      "default": "./contracts/api-key.ts"
    },
    "./contracts/common": {
      "types": "./contracts/common.ts",
      "require": "./contracts/common.js",
      "import": "./contracts/common.ts",
      "default": "./contracts/common.ts"
    },
    "./plans": {
      "types": "./plans.d.ts",
      "browser": "./plans.mjs",
      "import": "./plans.mjs",
      "require": "./plans.cjs",
      "default": "./plans.mjs"
    }
  },
  "peerDependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "zod": "^4.3.6"
  }
}
